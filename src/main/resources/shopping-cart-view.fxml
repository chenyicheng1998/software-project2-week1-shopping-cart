<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox fx:id="rootContainer" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      fx:controller="com.spring.ShoppingCartController"
      spacing="10" alignment="TOP_LEFT">
    <padding>
        <Insets top="16" right="16" bottom="16" left="16"/>
    </padding>

    <Label fx:id="titleLabel" style="-fx-font-size: 20px; -fx-font-weight: bold;"/>

    <HBox spacing="8">
        <Label fx:id="languageLabel"/>
        <ComboBox fx:id="languageCombo" prefWidth="200"/>
    </HBox>

    <HBox spacing="8">
        <Label fx:id="numberOfItemsLabel" minWidth="220"/>
        <TextField fx:id="numberOfItemsField" prefWidth="200"/>
    </HBox>

    <HBox spacing="8">
        <Label fx:id="priceLabel" minWidth="220"/>
        <TextField fx:id="priceField" prefWidth="200"/>
    </HBox>

    <HBox spacing="8">
        <Label fx:id="quantityLabel" minWidth="220"/>
        <TextField fx:id="quantityField" prefWidth="200"/>
    </HBox>

    <HBox spacing="10">
        <Button fx:id="addItemButton" onAction="#handleAddItem"/>
        <Button fx:id="calculateButton" onAction="#handleCalculate"/>
    </HBox>

    <Label fx:id="outputLabel"/>
    <TextArea fx:id="outputArea" prefHeight="260" wrapText="true"/>
</VBox>
